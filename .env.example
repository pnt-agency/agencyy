# Copy this file to .env.local and fill in real values. .env.local is gitignored.

# ---------- Database (Postgres, via Docker Compose) ----------
# These three are used by docker-compose.yml to configure the Postgres container.
POSTGRES_USER=agencybuild
POSTGRES_PASSWORD=change-me
POSTGRES_DB=agencybuild
POSTGRES_PORT=5432

# Used by the app (Drizzle) to connect to the database above.
# Host is "localhost" because the app runs outside Docker for now;
# the port must match POSTGRES_PORT.
DATABASE_URL=postgresql://agencybuild:change-me@localhost:5432/agencybuild

# ---------- NextAuth ----------
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# Optional — enables "Continue with Google". Leave blank to disable that button.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---------- Email (Resend) ----------
RESEND_API_KEY=re_your_resend_api_key

# Sender address. Leave unset to use Resend's sandbox sender
# ("Agency Build <onboarding@resend.dev>"), which needs no domain setup but
# ONLY delivers to the email your Resend account is registered under —
# everything addressed elsewhere is rejected. Verify a domain at
# resend.com/domains, then set this to an address on it to send to real users.
EMAIL_FROM=

# Where new-application / new-inquiry notifications are sent. If unset, no
# internal notification is sent (applicant confirmations still go out).
# While on the sandbox sender, set this to your Resend account email — it's
# the one address Resend will actually deliver to.
ADMIN_NOTIFICATION_EMAIL=
